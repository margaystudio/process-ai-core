# ============================================
# CONFIGURACIÓN DE AMBIENTES - BACKEND
# ============================================
# Copia este archivo a .env.local, .env.test o .env.production
# según el ambiente que quieras usar.

# ============================================
# AMBIENTE
# ============================================
# Valores: local, test, production
ENVIRONMENT=local

# ============================================
# OPENAI CONFIGURATION
# ============================================
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL_TEXT=gpt-4.1-mini
OPENAI_MODEL_TRANSCRIBE=gpt-4o-mini-transcribe
OPENAI_MODEL_TRANSCRIBE_TIMESTAMPS=whisper-1
# Modelo "barato" para tareas de bajo costo (clasificación, extracción, relaciones
# candidatas). Si se deja vacío, se usa OPENAI_MODEL_TEXT. Ver estrategia de costos IA.
OPENAI_MODEL_TEXT_CHEAP=
# Embeddings para chunks/RAG de Tyto (reservado, aún no usado).
OPENAI_MODEL_EMBEDDING=text-embedding-3-small

# ============================================
# OCR LOCAL (Tesseract — wizard evidencias, Fase 1.2)
# ============================================
# Requiere el binario de Tesseract instalado en el sistema.
# Windows: instalador UB-Mannheim → configurar ruta si no está en PATH:
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
# Linux/CI: apt-get install tesseract-ocr tesseract-ocr-spa
TESSERACT_CMD=
OCR_LANGUAGES=spa+eng

# ============================================
# CAPA SEMÁNTICA (relaciones / Tyto)
# ============================================
# Modo degradado. En dev/local dejalo en true: si falta pgvector/pg_trgm o la
# columna embedding quedó TEXT, el sistema arranca igual (sin vector search).
# En prod se recomienda false (estricto): el preflight FALLA al arrancar si la
# infra no está completa. Si no se setea, el default se deriva de ENVIRONMENT
# (prod/production => false; cualquier otro => true).
SEMANTIC_ALLOW_DEGRADED=true

# Autoconfirmación de relaciones candidatas (opcional; OFF por defecto).
# Sin setear: TODA relación propuesta por la IA va a revisión humana (ADR-006).
# Si se setea un umbral 0.0–1.0, las candidatas con confidence >= umbral se
# marcan 'confirmed' automáticamente (created_by_ai=true, confirmed_by=NULL =>
# "confirmada por el sistema"). Opt-in operativo; dejalo sin setear salvo que
# sepas lo que hacés.
# RELATION_AUTOCONFIRM_THRESHOLD=0.9

# ============================================
# DATABASE CONFIGURATION (Supabase Postgres — schema process_ai)
# ============================================
# Mismo proyecto Supabase que auth/hub/workspace. Schema dedicado: process_ai
# Supabase → Settings → Database → Connection string (Transaction pooler, :6543)
DATABASE_URL=postgresql+psycopg://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
DATABASE_SCHEMA=process_ai

# Caché en memoria para sync/auth (segundos). Reduce round-trips a Supabase remoto.
# REQUEST_CACHE_TTL_SECONDS=120

# ============================================
# API CONFIGURATION
# ============================================
API_HOST=0.0.0.0
API_PORT=8000

# ============================================
# CORS CONFIGURATION
# ============================================
# URLs permitidas para CORS (separadas por comas)
# Local
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Test (ejemplo)
# CORS_ORIGINS=https://test.yourapp.com

# Production (ejemplo)
# CORS_ORIGINS=https://yourapp.com

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=INFO
# Valores: DEBUG, INFO, WARNING, ERROR, CRITICAL

# ============================================
# MARGAY WORKSPACE (control plane)
# ============================================
WORKSPACE_URL=https://margay-workspace-513594124246.us-central1.run.app
PROCESS_AI_APP_KEY=process_ai

# ============================================
# SUPABASE
# ============================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================
# ALMACENAMIENTO DE ARTEFACTOS (PDF, imágenes, json/md)
# ============================================
# backend: "local" (disco, dev/test) | "supabase" (Supabase Storage, prod)
STORAGE_BACKEND=local
SUPABASE_STORAGE_BUCKET=process-ai-artifacts

# ============================================
# ARTIFACT SIGNING (requerido en prod)
# ============================================
ARTIFACT_SIGNING_SECRET=generate-a-long-random-secret
API_BASE_URL=https://api.yourapp.com
ARTIFACT_URL_TTL_SECONDS=900
