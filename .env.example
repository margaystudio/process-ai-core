# ============================================
# CONFIGURACIÓN DE AMBIENTES - BACKEND
# ============================================
# Copia este archivo a .env.local, .env.test o .env.production
# según el ambiente que quieras usar.

# ============================================
# AMBIENTE
# ============================================
# Valores: local, test, production
ENVIRONMENT=local

# ============================================
# OPENAI CONFIGURATION
# ============================================
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL_TEXT=gpt-4.1-mini
OPENAI_MODEL_TRANSCRIBE=gpt-4o-mini-transcribe
OPENAI_MODEL_TRANSCRIBE_TIMESTAMPS=whisper-1

# ============================================
# DATABASE CONFIGURATION (Supabase Postgres — schema process_ai)
# ============================================
# Mismo proyecto Supabase que auth/hub/workspace. Schema dedicado: process_ai
# Supabase → Settings → Database → Connection string (Transaction pooler, :6543)
DATABASE_URL=postgresql+psycopg://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
DATABASE_SCHEMA=process_ai

# Caché en memoria para sync/auth (segundos). Reduce round-trips a Supabase remoto.
# REQUEST_CACHE_TTL_SECONDS=120

# ============================================
# API CONFIGURATION
# ============================================
API_HOST=0.0.0.0
API_PORT=8000

# ============================================
# CORS CONFIGURATION
# ============================================
# URLs permitidas para CORS (separadas por comas)
# Local
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Test (ejemplo)
# CORS_ORIGINS=https://test.yourapp.com

# Production (ejemplo)
# CORS_ORIGINS=https://yourapp.com

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=INFO
# Valores: DEBUG, INFO, WARNING, ERROR, CRITICAL

# ============================================
# MARGAY WORKSPACE (control plane)
# ============================================
WORKSPACE_URL=https://margay-workspace-513594124246.us-central1.run.app
PROCESS_AI_APP_KEY=process_ai

# ============================================
# SUPABASE
# ============================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================
# ARTIFACT SIGNING (requerido en prod)
# ============================================
ARTIFACT_SIGNING_SECRET=generate-a-long-random-secret
API_BASE_URL=https://api.yourapp.com
ARTIFACT_URL_TTL_SECONDS=900
