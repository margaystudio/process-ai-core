# ============================================
# PRODUCCIÓN — process-ai-core (backend)
# ============================================
# cp .env.production.example .env.production
# Completá PASSWORD desde Supabase → Settings → Database → Transaction pooler (:6543)
# NO versionar .env.production

ENVIRONMENT=production

# Supabase PROD (ref mqldatizgvmjqisuqabv)
DATABASE_URL=postgresql+psycopg://postgres.mqldatizgvmjqisuqabv:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
DATABASE_SCHEMA=process_ai

SUPABASE_URL=https://mqldatizgvmjqisuqabv.supabase.co
SUPABASE_JWKS_URL=https://mqldatizgvmjqisuqabv.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_SERVICE_ROLE_KEY=

# Control plane (actualizar cuando workspace prod use Supabase prod)
WORKSPACE_URL=https://margay-workspace-513594124246.us-central1.run.app
PROCESS_AI_APP_KEY=process_ai

API_BASE_URL=https://api.process.margaystudio.io
CORS_ORIGINS=https://process.margaystudio.io,https://hub.margaystudio.io

OPENAI_API_KEY=
OPENAI_MODEL_TEXT=gpt-4.1-mini
OPENAI_MODEL_TRANSCRIBE=gpt-4o-mini-transcribe
OPENAI_MODEL_TRANSCRIBE_TIMESTAMPS=whisper-1

# Capa semántica: estricto en prod. Con false, el preflight FALLA al arrancar si
# falta pgvector/pg_trgm, la columna embedding no es 'vector', o falta OPENAI_API_KEY.
# (Si no se setea, ENVIRONMENT=production ya lo deriva a false.)
SEMANTIC_ALLOW_DEGRADED=false

ARTIFACT_SIGNING_SECRET=
ARTIFACT_URL_TTL_SECONDS=900

# Almacenamiento de artefactos (PDF aprobado, imágenes, json/md).
# En prod DEBE ser "supabase" (el disco del contenedor es efímero).
# Usa SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY de arriba.
STORAGE_BACKEND=supabase
SUPABASE_STORAGE_BUCKET=process-ai-artifacts

LOG_LEVEL=WARNING
