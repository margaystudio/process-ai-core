# Multi-stage Next.js build for Cloud Run
# NEXT_PUBLIC_* vars se hornean en build-time (ops/ui/release.py → build_args)

FROM node:20-alpine AS deps

WORKDIR /app/ui

COPY ui/package.json ui/package-lock.json ./
RUN npm ci

FROM node:20-alpine AS builder

WORKDIR /app/ui

COPY --from=deps /app/ui/node_modules ./node_modules
COPY ui/ ./

ARG NEXT_PUBLIC_API_URL
ARG NEXT_PUBLIC_SUPABASE_URL
ARG NEXT_PUBLIC_SUPABASE_ANON_KEY
ARG NEXT_PUBLIC_HUB_URL
ARG NEXT_PUBLIC_SITE_URL
ARG NEXT_PUBLIC_ENVIRONMENT
ENV NEXT_PUBLIC_API_URL=${NEXT_PUBLIC_API_URL}
ENV NEXT_PUBLIC_SUPABASE_URL=${NEXT_PUBLIC_SUPABASE_URL}
ENV NEXT_PUBLIC_SUPABASE_ANON_KEY=${NEXT_PUBLIC_SUPABASE_ANON_KEY}
ENV NEXT_PUBLIC_HUB_URL=${NEXT_PUBLIC_HUB_URL}
ENV NEXT_PUBLIC_SITE_URL=${NEXT_PUBLIC_SITE_URL}
ENV NEXT_PUBLIC_ENVIRONMENT=${NEXT_PUBLIC_ENVIRONMENT}

RUN npm run build

FROM node:20-alpine AS runner

WORKDIR /app/ui

ARG NEXT_PUBLIC_API_URL
ARG NEXT_PUBLIC_SUPABASE_URL
ARG NEXT_PUBLIC_SUPABASE_ANON_KEY
ARG NEXT_PUBLIC_HUB_URL
ARG NEXT_PUBLIC_SITE_URL
ARG NEXT_PUBLIC_ENVIRONMENT
ENV NEXT_PUBLIC_API_URL=${NEXT_PUBLIC_API_URL}
ENV NEXT_PUBLIC_SUPABASE_URL=${NEXT_PUBLIC_SUPABASE_URL}
ENV NEXT_PUBLIC_SUPABASE_ANON_KEY=${NEXT_PUBLIC_SUPABASE_ANON_KEY}
ENV NEXT_PUBLIC_HUB_URL=${NEXT_PUBLIC_HUB_URL}
ENV NEXT_PUBLIC_SITE_URL=${NEXT_PUBLIC_SITE_URL}
ENV NEXT_PUBLIC_ENVIRONMENT=${NEXT_PUBLIC_ENVIRONMENT}

ENV NODE_ENV=production

COPY --from=deps /app/ui/node_modules ./node_modules
COPY --from=builder /app/ui/.next ./.next
COPY --from=builder /app/ui/public ./public
COPY --from=builder /app/ui/package.json ./package.json

EXPOSE 8080
CMD ["npx", "next", "start", "-p", "8080"]
