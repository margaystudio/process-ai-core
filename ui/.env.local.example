# ============================================
# CONFIGURACIÓN LOCAL - FRONTEND (process-ai)
# ============================================
# Copiá este archivo a .env.local y completá los valores.
# Ver guía de entorno local: ui/README.dev.md

NEXT_PUBLIC_ENVIRONMENT=local

# Backend FastAPI (HTTPS local — corre con certificados de mkcert, ver README.dev.md)
NEXT_PUBLIC_API_URL=https://api.local.margaystudio.io:8300

# Hub de autenticación (margay-hub)
# Local: https://hub.local.margaystudio.io:3001  |  Prod: https://hub.margaystudio.io
NEXT_PUBLIC_HUB_URL=https://hub.local.margaystudio.io:3001

# Dominio de cookie compartida entre módulos (SSO).
# Local: .local.margaystudio.io  |  Prod: lo resuelve el código por NODE_ENV
NEXT_PUBLIC_COOKIE_DOMAIN=.local.margaystudio.io

# Supabase (proyecto compartido del ecosistema)
NEXT_PUBLIC_SUPABASE_URL=https://nbigcpjmckewuhrqjzrt.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<pedir-al-equipo>
