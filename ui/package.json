{
  "name": "process-ai-ui",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev:setup": "bash scripts/dev-setup.sh",
    "dev:setup:win": "powershell -ExecutionPolicy Bypass -File scripts/dev-setup.ps1",
    "dev": "cross-env NODE_OPTIONS=--max-http-header-size=65536 next dev -p 3000 -H process.local.margaystudio.io --experimental-https --experimental-https-key .certs/local-margay-key.pem --experimental-https-cert .certs/local-margay.pem",
    "dev:plain": "cross-env NODE_OPTIONS=--max-http-header-size=65536 next dev",
    "dev:test": "cross-env NODE_ENV=test NODE_OPTIONS=--max-http-header-size=65536 next dev --port 3001",
    "build": "next build",
    "build:test": "cross-env NODE_ENV=test next build",
    "build:prod": "next build",
    "start": "next start",
    "start:test": "cross-env NODE_ENV=test next start --port 3001",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "^2.89.0",
    "@tiptap/extension-image": "^2.10.0",
    "@tiptap/extension-link": "^2.10.0",
    "@tiptap/extension-placeholder": "^2.10.0",
    "@tiptap/extension-table": "^2.10.0",
    "@tiptap/extension-table-cell": "^2.10.0",
    "@tiptap/extension-table-header": "^2.10.0",
    "@tiptap/extension-table-row": "^2.10.0",
    "@tiptap/pm": "^2.10.0",
    "@tiptap/react": "^2.10.0",
    "@tiptap/starter-kit": "^2.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "next": "14.0.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwind-merge": "^2.6.1"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.0.1",
    "cross-env": "^7.0.3",
    "eslint": "^8",
    "eslint-config-next": "14.0.4",
    "jsdom": "^29.1.1",
    "postcss": "^8",
    "tailwindcss": "^3.3.0",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
